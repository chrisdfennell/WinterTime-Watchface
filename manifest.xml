<iq:manifest version="3" xmlns:iq="http://www.garmin.com/xml/connectiq">
    <!--
        Snowfall - a winter alpine watch face. Originally built for the Garmin
        tactix 8 / Fenix 8 (AMOLED), now targeting CIQ 4.0+ round watches that
        support watch faces. Square/rectangular panels (Venu Sq 2, Venu X1) are
        excluded - the circular layout is designed for round screens. The face is
        laid out relative to
        dc.getWidth()/getHeight() and the screen center, so it scales across all
        panel sizes; tools/gen_fonts.py bakes a correctly-sized bitmap font set for
        each distinct resolution and monkey.jungle maps every product to its set.

        Device families below mirror the broad coverage of the Tamawatchi project
        (Forerunner, fenix/epix/enduro, Venu/Vivoactive, Instinct, and the golf /
        dive / aviation / MARQ specialty watches). Edge bike computers and handheld
        GPS units are excluded (they are not watches / do not run watch faces).

        minApiLevel 4.0.0 guarantees vector fonts (3.4+) and the Body Battery
        SensorHistory API (4.0+). All optional features are still guarded with
        `has` checks at runtime so nothing crashes on a device that lacks them.
    -->
    <iq:application id="d353bcc4-f3de-4b13-93d8-6adb176564b6" type="watchface" name="@Strings.AppName" entry="SnowfallApp" launcherIcon="@Drawables.LauncherIcon" minApiLevel="4.0.0">
        <iq:products>
            <!-- Forerunner -->
            <iq:product id="fr165"/>
            <iq:product id="fr165m"/>
            <iq:product id="fr255"/>
            <iq:product id="fr255m"/>
            <iq:product id="fr255s"/>
            <iq:product id="fr255sm"/>
            <iq:product id="fr265"/>
            <iq:product id="fr265s"/>
            <iq:product id="fr57042mm"/>
            <iq:product id="fr57047mm"/>
            <iq:product id="fr955"/>
            <iq:product id="fr965"/>
            <iq:product id="fr970"/>

            <!-- fenix / epix / enduro -->
            <iq:product id="fenix7"/>
            <iq:product id="fenix7pro"/>
            <iq:product id="fenix7pronowifi"/>
            <iq:product id="fenix7s"/>
            <iq:product id="fenix7spro"/>
            <iq:product id="fenix7x"/>
            <iq:product id="fenix7xpro"/>
            <iq:product id="fenix7xpronowifi"/>
            <iq:product id="fenix843mm"/>
            <iq:product id="fenix847mm"/>
            <iq:product id="fenix8pro47mm"/>
